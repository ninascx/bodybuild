    const nextChecks = {
      ...taskChecks,
      [today]: {
        ...defaultChecks,
        ...checks,
        [key]: !checks[key],
      },
    }
    schedulePersist({ dailyLogs, workoutLogs, taskChecks: nextChecks, workoutTemplates }, true)
  }

